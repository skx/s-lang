##
## Test mmap and call.
##



#
# Code is where we assemble the instructions to,
# and later execute.
#
let code = mmap(65536);

#
# Tape is our brainfuck tape-space
#
let tape = malloc(3000);

#
# PC keeps track of where we're emitting code to,
# within the code array.
#
let pc = 0;

# push r12
code[pc] = 0x41; pc++;
code[pc] = 0x54; pc++;

# mov r12, imm64
code[pc] = 0x49; pc++;
code[pc] = 0xBC; pc++;

emit64(tape);

# pop r12
code[pc] = 0x41; pc++;
code[pc] = 0x5C; pc++;

# ret
code[pc] = 0xC3; pc++;

#
# Now execute it :pray:
#
call(code);

#
# All done
#
exit(0);


# word
function emit32(v) {
   code[pc] =  v        & 0xFF;
   pc++;
   code[pc] = (v >>  8) & 0xFF;
   pc++;
   code[pc] = (v >> 16) & 0xFF;
   pc++;
   code[pc] = (v >> 24) & 0xFF;
   pc++;
}

# double-word
function emit64(x) {
  let i = 0;
  while( i < 8 ) {
       code[pc]  = (x >> (i * 8)) & 255;
       pc++;
       i++;
  }
}
