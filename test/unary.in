# Unary minus note "-x" work.
# but "--x" would look like the postfix -- token, and would fail.
print( -1 , "\n");
print( - -1 , "\n");
print( - - -1 , "\n");

# not - int 
print( !32, "\n");
print( !!32, "\n");
print( !!!32, "\n");
print( !!!!32, "\n");

# not - float
print( !3.2, "\n");
print( !!3.2, "\n");
print( !!!3.2, "\n");
print( !!!!3.2, "\n");


# plus is basically a nop.
print( +3, "\n");
print( + +3, "\n");
print( +3.3, "\n");
print( + +3.3, "\n");
