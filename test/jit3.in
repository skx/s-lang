##
## We don't have closures, so we cannot implement a "counter()" or
## makeAdder(3); function as is traditional.
##
## However with binary code we can achieve the same results ..
##
## This is fun.

#
# The binary code will be stored here.
#
let code = 0;
if ( type(code) == "INTEGER") {
   # Only create it once
   createCounter();
}


#
# Now we'll have a counter function, so call it a bunch of times.
#
let i = 0;
while( i < 10 ) {
  print( counter() , "\n" );
  print( counter() , "\n");
  i++;
}


#
# Call the code, returning the next value.
#
function counter() {
   call(code);
}

#
# Create an adder
#
function createCounter() {
   code = mmap(18);    # Where our executable code lives.
   stor = malloc(4);   # Where we store our state
   pc = 0;

   # mov rax, addr data
   code[pc] = 0x48; pc++;
   code[pc] = 0xC7; pc++;
   code[pc] = 0xC0; pc++;

   # Encode the address of the state.
   value = addr(stor);
   code[pc] = value % 256;
   pc++;
   code[pc] = float2int(value / 256) % 256;
   pc++;
   code[pc] = float2int(value / 65536) % 256;
   pc++
   code[pc] = float2int(value / 16777216) % 256;
   pc++

   # inc dword ptr [rax]
   code[pc] = 0xFF;
   pc++
   code[pc] = 0x00;
   pc++

   # mov rax, dword ptr[rax]
   code[pc] = 0x48;
   pc++
   code[pc] = 0x63;
   pc++
   code[pc] = 0x00;
   pc++

   # sal rax, 2
   code[pc] = 0x48;
   pc++
   code[pc] = 0xC1;
   pc++
   code[pc] = 0xE0;
   pc++
   code[pc] = 0x02;
   pc++

   # ret
   code[pc] = 0xC3; pc++;

   if ( pc != 17 ) {
      panic("code had unexpected size!\n");
   }
}