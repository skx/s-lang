let sum = 0;

let a = 0;
while( a < 10 ) {

   let a = a + 1;

   let b = 0;
   while( b < 10 ) {

      let b = b + 1;
      let sum = sum + 1;
   }
}

print("SUM:", sum, "\n");


#
# Test that we have working loops for integer and float conditions.
#

let c = int2float(10);
while( c ) {
  print("float loop ", c, " type: ", type(c), "\n");
  let c = c - 1;
}

let a = 10;
while( a > 0 ) {
  print("int loop ", a, " type: ", type(a), "\n");
  let a = a - 1;
}
