#
# This file contains tests for our comparison operations.
#
# These tests attempt to fully-exercise the comparisons by using
# a combination of types:
#
#    INT   OP INT
#    FLOAT OP INT
#    INT   OP FLOAT
#    FLOAT OP FLOAT
#
# There are both positive tests, which should succeed, and negative
# tests which should fail in order to validate I've implemented the
# conversion and ordering correctly.
#



##
## ==
##

if ( 1 == 1 )     {  print("OK\n"); } else { print( "Failed\n"); }
if ( 1.0 == 1 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 1 == 1.0 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 2.5 == 2.5 ) {  print("OK\n"); } else { print( "Failed\n"); }

if ( 3 == 1 )     {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3.0 == 1 )   {  print("Failed\n"); } else { print( "OK\n"); }
if ( 1 == 3.0 )   {  print("Failed\n"); } else { print( "OK\n"); }
if ( 2.5 == 3.5 ) {  print("Failed\n"); } else { print( "OK\n"); }


##
## Other types
##
if ( "Steve" == 1 )   { print("FAILED\n"); } else {print("string != 1\n");}
if ( 1 == "Steve"  )  { print("FAILED\n"); } else {print("string != 1\n");}
if ( 1.5 == "Steve" ) { print("FAILED\n"); } else {print("string != 1.5\n");}
if ( "Test" == 1.5 )  { print("FAILED\n"); } else {print("string != 1.5\n");}

#
# String comparisons
#
a = "Me";
b = "Me";
if ( "Steve" == "Steve") { print("OK\n"); } else { print("string != string\n"); }
if ( a == b ) { print("OK\n"); } else { print("string != string\n"); }

#
# Ensure we have different pointer addresses
#
a = strdup("Me");
b = strdup("Me");
if ( a == b ) { print("comparing works even on copies\n"); } else { print("failed\n"); }


##
## !=
##

if ( 10 != 1 )     {  print("OK\n"); } else { print( "Failed\n"); }
if ( 10.0 != 1 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 1 != 10.0 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 2.5 != 20.5 ) {  print("OK\n"); } else { print( "Failed\n"); }

if ( 3 != 3 )     {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3.0 != 3 )   {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3 != 3.0 )   {  print("Failed\n"); } else { print( "OK\n"); }
if ( (1 / 3) != ( 1 / 3 ) ) {  print("Failed\n"); } else { print( "OK\n"); }



##
## <
##

if ( 1 < 10 )     {  print("OK\n"); } else { print( "Failed\n"); }
if ( 10.0 < 100 ) {  print("OK\n"); } else { print( "Failed\n"); }
if ( 1 < 10.0 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 25.0 < 100.0 ) {  print("OK\n"); } else { print( "Failed\n"); }

if ( 30 < 9 )        {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3.0 < 3 )       {  print("Failed\n"); } else { print( "OK\n"); }
if ( 33 < 3.0 )      {  print("Failed\n"); } else { print( "OK\n"); }
if ((2 / 3) < (1/3)) {  print("Failed\n"); } else { print( "OK\n"); }



##
## >
##

if ( 10 > 1 )       {  print("OK\n"); } else { print( "Failed\n"); }
if ( 100.0 > 10 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 10 > 1.0 )     {  print("OK\n"); } else { print( "Failed\n"); }
if ( 100.0 > 25.0 ) {  print("OK\n"); } else { print( "Failed\n"); }

if ( 9 > 39 )       {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3 > 3.0 )      {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3 > 33.0 )     {  print("Failed\n"); } else { print( "OK\n"); }
if ( (1/3) > (2/3)) {  print("Failed\n"); } else { print( "OK\n"); }



##
## >=
##

if ( 10 >= 10 )       {  print("OK\n"); } else { print( "Failed\n"); }
if ( 100.0 >= 100 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 10 >= 10.0 )     {  print("OK\n"); } else { print( "Failed \n"); }
if ( 100.0 >= 100.0 ) {  print("OK\n"); } else { print( "Failed\n"); }

if ( 9 >= 39 )    {  print("Failed\n"); } else { print( "OK\n"); }
if ( 2 >= 3.0 )   {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3.0 >= 30 )  {  print("Failed\n"); } else { print( "OK\n"); }
if ( 0.5 >= 1.5)  {  print("Failed\n"); } else { print( "OK\n"); }



##
## <=
##

if ( 10 <= 10 )       {  print("OK\n"); } else { print( "Failed\n"); }
if ( 100.0 <= 100 )   {  print("OK\n"); } else { print( "Failed\n"); }
if ( 10 <= 10.0 )     {  print("OK\n"); } else { print( "Failed\n"); }
if ( 100.0 <= 100.0 ) {  print("OK\n"); } else { print( "Failed\n"); }

if ( 29 <= 9 )      {  print("Failed\n"); } else { print( "OK\n"); }
if ( 20 <= 3.0 )    {  print("Failed\n"); } else { print( "OK\n"); }
if ( 3.25 <= 3.15 ) {  print("Failed\n"); } else { print( "OK\n"); }
if ( 1.7 <= 1.2 )   {  print("Failed\n"); } else { print( "OK\n"); }
