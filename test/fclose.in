#
# file closing
#


## type failures
print( fclose( "steve" ), "\n");
print( fclose(    1/3  ), "\n");

# closing STDERR is fine
print("Closing STDERR\n");
print( fclose(2), "\n" );
print("Still seeing output to STDOUT\n");

# but after closing STDOUT we'll see no further output.
fclose(1);

print("This should be invisible .. STDOUT is no more\n");
putc(42);
putc(10);