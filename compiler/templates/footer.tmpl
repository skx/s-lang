.align 16
sigaction_struct_sigint:
    .quad sigint_handler     # sa_handler
    .quad SA_RESTORER        # sa_flags
    .quad sigint_restorer    # sa_restorer
    .quad 0
    .quad 0

.align 16
sigaction_struct_sigfpe:
    .quad sigfpe_handler     # sa_handler
    .quad SA_RESTORER        # sa_flags
    .quad sigint_restorer    # sa_restorer
    .quad 0
    .quad 0


.section .data
.align 8
SIGFPE_CAUGHT:
