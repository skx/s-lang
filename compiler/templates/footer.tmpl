        #
        # Exit explicitly, just in case the program was missing a
        # terminating RETURN statement.
        #
        xor rax, rax
        jmp exit


#####
#####  Standard Library
#####

{{template "stdlib" .}}


#####
#####  Stored pointers to command line arguments, environment, etc.
#####

.section .bss
.align 8

#
# Pointer to the start of the environmental variables.
#
# (used by "getenv".)
#
envp_ptr:
        .quad 0

#
# Count of arguments passed to the binary.
#
# (used by "argc".)
#
argument_count:
        .quad 0

#
# Pointer to the start of the argument variables array.
#
# (used by "argv".)
#
argument_base:
        .quad 0

#
# Temporary holder for flags; used to enable the use of
# a floating-point exception for floating-point divisions.
#
mxcsr:
        .quad 0


#####
#####  Handlers for SIGINT (Ctrl-C) and SIGFPE (division by zero).
#####

.section .text

# Function called on SIGINT
sigint_handler:

       # call the optional "sigint" user_function, if present.
.ifdef sigint
       call sigint
.else
       mov rax, offset SIGINT_CAUGHT
       call print_string_raw
.endif

       # call the optional "at_exit" user_function, if present.
.ifdef at_exit
       call at_exit
.endif

       mov rax, 60  # SYS_exit
       xor rdi, rdi
       syscall

sigfpe_handler:

       # call the optional "sigfpe" user_function, if present.
.ifdef sigfpe
       call sigfpe
.else
       mov rax, offset SIGFPE_CAUGHT
       call print_string_raw
.endif

       # call the optional "at_exit" user_function, if present.
.ifdef at_exit
       call at_exit
.endif

       mov rax, 60  # SYS_exit
       xor rdi, rdi
       syscall

sigint_restorer:
       mov rax, 15  # SYS_rt_sigreturn
       syscall

#
# Linux x86-64 sigaction flags
#
.equ SA_RESTORER, 0x04000000

#
# struct sigaction
#
# struct sigaction {
#     void (*sa_handler)(int);
#     unsigned long sa_flags;
#     void (*sa_restorer)(void);
#     sigset_t sa_mask;
# };
#
.section code
sigint_fail:
        mov rax, offset int_fail
        call print_string_raw
        call exit

.section .data

.align 8
int_fail:
        .ascii "signal setup failed\n"
        .byte 0

.align 16
sigaction_struct_sigint:
    .quad sigint_handler     # sa_handler
    .quad SA_RESTORER        # sa_flags
    .quad sigint_restorer    # sa_restorer
    .quad 0
    .quad 0

.align 16
sigaction_struct_sigfpe:
    .quad sigfpe_handler     # sa_handler
    .quad SA_RESTORER        # sa_flags
    .quad sigint_restorer    # sa_restorer
    .quad 0
    .quad 0


.section .data
.align 8
SIGFPE_CAUGHT:
        .ascii "Caught SIGFPE (floating-point exception)!\nTerminating!\n"
        .byte 0

.align 8
SIGINT_CAUGHT:
        .ascii "Caught SIGINT (Ctrl-C)!\nTerminating!\n"
        .byte 0

