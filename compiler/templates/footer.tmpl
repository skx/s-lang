        #
        # Exit explicitly, just in case the program was missing a
        # terminating RETURN statement.
        #
        mov rax, 0
        push rax
        mov rax, 1
        call exit


#####
#####  Standard Library
#####

{{template "stdlib" .}}


#####
#####  Stored pointers to command line arguments, environment, etc.
#####

.section .bss
.align 8

#
# Pointer to the start of the environmental variables.
#
# (used by "getenv".)
#
envp_ptr:
        .quad 0

#
# Count of arguments passed to the binary.
#
# (used by "argc".)
#
argument_count:
        .quad 0

#
# Pointer to the start of the argument variables array.
#
# (used by "argv".)
#
argument_base:
        .quad 0

#
# Temporary holder for flags; used to enable the use of
# a floating-point exception for floating-point divisions.
#
mxcsr:
        .quad 0

#
# Marker to indicate whether the user-defined "at_exit"
# function has been called.
#
# The function might include an exit statement so we want
# to avoid recursion and ensure it is only called once.
#
at_exit_called:
        .quad 0

#####
#####  Handlers for SIGINT (Ctrl-C) and SIGFPE (division by zero).
#####

.section .text

# Function called on SIGINT
sigint_handler:

       # call the optional "sigint" user_function, if present.
.ifdef sigint
       call sigint
.else
       mov rax, offset SIGINT_CAUGHT
       call print_string_raw
.endif

       # call the optional "at_exit" user_function, if present.
       # but only once.  We don't want to call recursively if
       # that function has an exit statement within it.
.ifdef at_exit
       cmp byte ptr [at_exit_called], 0
       jne 1f

       mov byte ptr [at_exit_called], 1
       call at_exit
1:
.endif

       mov rax, 60  # SYS_exit
       xor rdi, rdi
       syscall

sigfpe_handler:

       # call the optional "sigfpe" user_function, if present.
.ifdef sigfpe
       call sigfpe
.else
       mov rax, offset SIGFPE_CAUGHT
       call print_string_raw
.endif

       # call the optional "at_exit" user_function, if present.
       # but only once.  We don't want to call recursively if
       # that function has an exit statement within it.
.ifdef at_exit
       cmp byte ptr [at_exit_called], 0
       jne 1f

       mov byte ptr [at_exit_called], 1
       call at_exit
1:
.endif

       mov rax, 60  # SYS_exit
       xor rdi, rdi
       syscall

sigint_restorer:
       mov rax, 15  # SYS_rt_sigreturn
       syscall

#
# Linux x86-64 sigaction flags
#
.equ SA_RESTORER, 0x04000000

#
# struct sigaction
#
# struct sigaction {
#     void (*sa_handler)(int);
#     unsigned long sa_flags;
#     void (*sa_restorer)(void);
#     sigset_t sa_mask;
# };
#
.section .text

#
# Signal setup failed, panic.
#
sigint_fail:
        mov rax, offset int_fail     # Message to display
        call panic_raw               # NOTE: Doesn't return

#
# Called when bounds check fails
#
out_of_bounds:
        mov rax, offset out_of_bounds_msg
        call panic_raw





