#
# Return the length of the given string
#

.section .text.strlen,"ax",@progbits

strlen:
        push rbp
        mov rbp, rsp

        mov rdi, [rbp+16]    # Get the string

        mov rcx, rdi         # type checking
        and rcx, 3
        cmp rcx, 1
        jne strlen_type_fail

        and rdi, -4         # Remove typing
        call strlen_raw     # Count the length
        sal rax, 2          # Add typing

.strlen_cleanup:
        mov rsp, rbp
        pop rbp
        ret

strlen_type_fail:
        mov rax, offset strlen_type_fail_msg
        or rax, 1
        jmp .strlen_cleanup

.section .data.strlen,"aw",@progbits

.align 8
strlen_type_fail_msg:
        .ascii "strlen: expected STRING"
        .byte 00
