#
# Return the length of the given string
#

.section .text.strlen,"ax",@progbits

strlen:
        push rbp
        mov rbp, rsp

        mov rdi, [rbp+16]    # Get the string
        and rdi, -2          # Remove typing

        xor rax, rax
.strlen_next_char:
        cmp byte ptr [rdi + rax], 0
        je .strlen_done
        inc rax
        jmp .strlen_next_char
.strlen_done:
        push rax            # save the result
        call alloc8         # allocate room for the result
        pop rbx             # get the result
        mov [rax], rbx      # store it
        or rax, 0           # mark it as an integer-pointer

        mov rsp, rbp
        pop rbp
        ret
