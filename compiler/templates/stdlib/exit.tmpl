#
# Exit the process with the status code stored in RAX
#
# NOTE
#######
#
# This is unlike all other internal functions,
# which use the stack for parameters and RAX
# for the argument count.
#
# This is because we compile "return; " statements
# specially.  If the user were to write "exit(33);"
# that would actually exit, but with the wrong
# value.  (RAX would be 1 for the argument count,
# and shifting that would result in an exit code of zero).
#

.section .text.exit,"ax",@progbits

exit:
        # save the value, in case we have an at_exit
        # function which will trash it.
        push rax


       # call the optional "at_exit" user_function, if present.
       # but only once.  We don't want to call recursively if
       # that function has an exit statement within it.
.ifdef at_exit
       cmp byte ptr [at_exit_called], 0
       jne 1f

       mov byte ptr [at_exit_called], 1
       call at_exit
1:
.endif

        #
        # restore the saved exit-value.
        #
        pop rax
        sar rax, 2
exit_with_rax:
        mov rdi, rax
        mov rax, 60     # sys_exit
        syscall
        ret
