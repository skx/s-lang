#
# Return a copy of the given string.
#

.section .text.strdup,"ax",@progbits

strdup:
        push rbp
        mov rbp, rsp

        mov rdi, [rbp+16]    # Get the string

        mov rcx, rdi         # type checking
        and rcx, 3
        cmp rcx, 1
        jne strdup_type_fail

        and rdi, -4          # Remove typing

        push rdi             # Get the length in RAX
        call strlen_raw
        pop  rdi

        #
        # RDI points to the string.
        # RAX has the length.
        #
        push rdi

        # Allocate the memory
        inc rax       # Add space for terminator
        sal rax, 2    # Add typing
        push rax      # store as stack-arg
        mov rax, 1    # one argument
        call malloc
        and rax, -4   # untype the result

        pop rdi          # Pointer to start of the string
        push rax         # Save the new allocation
        mov  rsi, rax    # Copy into place
        call strcpy_raw
        pop  rax         # Restore the allocated-pointer
        or rax, 1        # Add typing

.strdup_cleanup:
        mov rsp, rbp
        pop rbp
        ret

strdup_type_fail:
        mov rax, offset strdup_type_fail_msg
        or rax, 1
        jmp .strdup_cleanup


.section .data.strdup,"aw",@progbits

.align 8
strdup_type_fail_msg:
        .ascii "strdup: expected STRING"
        .byte 00
