#
# Implementation of our mathematical operations: modulus
#
# In all cases the arguments will be stored in RAX and RBX
#


.section .text.modulus,"ax",@progbits

modulus:
        # Check tags
        mov rcx, rax
        or rcx, rbx
        and rcx, 3
        cmp rcx, 0
        jne .modulus_type_error

        # integer fast path
        sar rax, 2                  # dividend
        sar rbx, 2                  # divisor

        xchg rax, rbx               # swap registers
        cqo                         # RDX:RAX
        idiv rbx                    # remainder -> RDX

        mov rax, rdx
        sal rax, 2                  # retag integer
        ret


.modulus_type_error:
        mov  rax, offset modulus_type_fail_msg
        or   rax, 1
        ret





.section .data.modulus,"aw",@progbits

.align 8
modulus_type_fail_msg:
        .ascii "%: expected INTEGER"
        .byte 0
