.section .text.alloc,"ax",@progbits

#
# Allocate eight bytes, and return the pointer to that allocation
#
# NOTE: This does not return a typed pointer (we remove the typing
# so that it may be used immediately).
#
alloc8:
        mov rax, 8     # eight bytes
        sal rax, 2     # shift left to add typing
        push rax
        call malloc    # Allocate the memory
        add rsp, 8
        and rax, -4    # Remove typing
        ret
