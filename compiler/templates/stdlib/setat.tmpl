#
# setat( "String", 0, 42 );  -> "*tring"
#

.section .text.setat,"ax",@progbits

setat:
        push rbp
        mov rbp, rsp
        mov rdi, [rbp+16]    # get the string
        and rdi, -2          # Undo typing
        mov rbx, [rbp+24]    # get the integer
        sar rbx, 2           # remove tag bits
        mov rax, [rbp+32]    # get the integer
        sar rax, 2           # remove tag bits

        mov [rdi + rbx], al  # set the byte
        movzx rax, al        # extend
        sal rax, 2           # add type-bits
        mov rsp, rbp
        pop rbp
        ret
