#
# Compare strings for equality.
#
# Return zero if equal, otherwise the ASCII difference
# of the first character which differs.
#

.section .text.strcmp,"ax",@progbits

strcmp:
        push rbp
        mov rbp, rsp

        mov rdi, [rbp+16]    # Get the string
        and rdi, -4          # Remove typing
        mov rsi, [rbp+24]    # Get the string
        and rsi, -4          # Remove typing

        xor rax, rax
.strcmp_next_char:
        mov al, [rdi]
        cmp al, [rsi]
        jne .strcmp_diff
        test al, al
        je .strcmp_done
        inc rdi
        inc rsi
        jmp .strcmp_next_char
.strcmp_diff:
        movzx rdx, byte ptr [rsi]
        sub al, dl
.strcmp_done:
        movsx rax, al       # Truncate, but keep the sign
        sal rax, 2          # set type
        mov rsp, rbp
        pop rbp
        ret
