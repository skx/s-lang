<<<<<]]>>>]
"


#
# No program by default
#
let program = " ";

#
# Ensure we have 1 argument - i.e. argc == 2.
#
if ( argc() != 2 ) {
   print("Usage: brainfuck cat|hello|mandelbrot|/path/to/file.bf\n");
   exit(1);
}

if (strcmp(argv(1),"cat") == 0 ) {
  let program = cat;
}

if (strcmp(argv(1),"hello") == 0 ) {
  let program = hello;
}

if (strcmp(argv(1),"mandelbrot") == 0 ) {
  let program = mandel;
}


# If we don't have a program, and there is a file
# that is non-empty, then read that.
if (strlen(program)< 2 && filesize( argv(1) ) > 0 ) {
   program = readfile( argv(1));
}

# At this point the program is empty, or the file read failed
if (strlen(program) < 2) {
   print("Usage: brainfuck cat|hello|mandelbrot|/path/to/file.bf\n");
   exit(1);
}


let length = strlen(program);
let index = 0;
let cellptr = 0;

# Allocate the memory for the cells
let ram = malloc(4096);

# Cache of open-close offsets.
let jumpOpen  = malloc(length * 2);
let jumpClose = malloc(length * 2);

#
# We want to store 0-65535 inside our stack, but we
# can't do that directly - only eight-bit values.
#
# (Well we don't need such big numbers, but we want
# to store offsets within our program - and the program
# will certainly be longer than 255 bytes.)
#
# Split it into two parts.
#
function setStack(stack, index, value) {
    stack[index*2]     = value % 256;
    stack[index*2 + 1] = float2int(value / 256);
}

#
# Helper to do the retrival.
#
function getStack(stack, index) {
    return( stack[index*2] + (256 * stack[index*2 + 1]) );
}

#
# Same story, we can't set a value bigger than 255 into
# our byte-array, so we have to split the value into two
# eight-bit pieces.
#
function setJump(table, index, value) {

    let low  = value % 256;
    let high = float2int(value / 256);

    table[index*2]     = low;
    table[index*2 + 1] = high;
}

#
# Get the value
#
function getJump(table, index) {

    let low  = table[index*2];
    let high = table[index*2 + 1];

    return(low + (256 * high));
}


#
# Build our jump tables for loop open/close
#
# We use a temporary stack here (never freed, oops), and
# populate the global "jumpOpen" and "jumpClose" arrays
# with the appropriate offsets.
#
function buildJumpTable() {

    let stack = malloc(length * 2);
    let sp = 0;
    let i = 0;

    while (i < length) {

        switch (program[i]) {

            case '[' {
               setStack(stack, sp, i);
               sp++;
            }

            case ']' {

               if (sp == 0) {
                  print("Unmatched ]\n");
                  return(1);
               }

               sp--

               let open = getStack(stack, sp);
               let close = i;

               #
               # '[' jumps to instruction after ']'
               #
               setJump(jumpOpen, open, close + 1);

               #
               # ']' jumps back to matching '['
               #
               setJump(jumpClose, close, open);
            }
        }
        i++;
    }

    if (sp != 0) {
        print("Unmatched [\n");
        return(1);
    }
    return(0);
}


#
# Build the jump table of cached
# loop indexes.
#
if ( buildJumpTable() != 0 ) {
   print("failed to succesfully build our jump table!\n");
   exit(0);
}


# while we have the program
while(index < length) {

   # Process the next character.
   #
   # NOTE: We use a switch-statement here so that we handle
   # each known opcode.
   #
   # Anything that isn't recognized as a valid instruction will be ignored.
   #
   switch (program[index]) {

     # +: increment the value at the cellptr
     case '+' {
        let n = ram[cellptr];
        n++;
        ram[cellptr] = n;
     }

     # -: decrement the value at the cellptr
     case '-' {
        let n = ram[cellptr];
        n--;
        ram[cellptr] = n;
     }

     # ,: read from STDIN
     case ',' {
        let x = getc();
        if ( x < 0 ) {
           # failed to read from STDIN
           exit( 1 );
        }
        ram[cellptr] = x;
     }

     # .: print contents of cellptr
     case '.' {
        let n = ram[cellptr];
        putc(n);
     }

     # <: decrement cellptr
     case '<' {
        cellptr--;
     }

     # >: increment cellptr
     case '>' {
       cellptr++;
     }

     # [: loop open
     case '[' {
        # is the byte at the data pointer zero?
        let n = ram[cellptr];
        if (n == 0) {
          let index = getJump(jumpOpen, index);
          continue;
        }
     }

     # ]: loop close
     case ']' {
        # is the byte at the data pointer zero?
        let n = ram[cellptr];
        if (n != 0) {
           let index = getJump(jumpClose, index);
           continue;
        }
     }
   }

   # next opcode
   index++;
}
