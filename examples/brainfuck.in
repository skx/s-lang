#
# brainfuck interpreter, launch with the name of the program to execute.
#
# For example:
#
#   ./brainfuck cat
#   ./brainfuck hello
#   ./brainfuck mandelbrot
#
# Any other argument will be assumed to be a filename to read.
#


let cat = ",[.,]"
