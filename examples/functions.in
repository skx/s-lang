#
# Simple functions which take no parameters, and
# return fixed values.
#
function four () {
   return( 4 );
}
function five () {
   return (3 + 2);
}

#
# Functions can have default parameters
#
function greet(name = "world!" ) {
   print( "Hello, ", name, "\n" );
}


#
# Perform the standard greeting.
#
greet();
greet("Steve!");


#
# Call the functions and confirm that works
#
let a = four();
let b = five();
print( "four() -> ", a, " five() -> ", b);
newline();


#
# Of course calling a function doesn't mean
# we have to care about the return value.
#
four();


#
# Set some global variables
#
let a = 13;
let b = 17;

print("Before function A is: ", a, "\n");
print("Before function B is: ", b, "\n");

#
# Define a function to show that it gets
# it's own scope, and the varibles have
# different values
#
function debug(my, name) {

   print("  Inside debug() A is ", a, "\n");
   print("  Inside debug() B is ", b, "\n");
   print("  Inside debug() MY is ", my, "\n");
   print("  Inside debug() NAME is ", name, "\n");

   let my = " my name";
   let name = "Marlo";
   print("  Inside debug() MY is ", my, "\n");
   print("  Inside debug() NAME is ", name, "\n");

}

#
# Call the function
#
debug(33, 42);

#
# And confirm the global scope is unchanged
#
print("A should still be 13: ", a, "\n");
print("B should still be 17: ", b, "\n");





#
# Return the maximum value of those
# values stored in variable A and B
#
function max (a, b ) {

   print("max() was called!\n");

   # If B > A then update A
   #
   # End result is A contains the
   # biggest of A and B.

   if ( b >= a ) {
      return( b );
   }
   return (a);
}

#
# Define a function with inline assembly
#
function steve () {
  inline {
     mov rax, 42   # store value
     sal rax, 2    # Add typing
     mov rsp, rbp  # cleanup stack-frame
     pop rbp
     ret
  }
}


let p = max(210, 121);
print("Result of max(): ", p, "\n");

let b = steve();
print("Result of steve() -> ", b, "\n");
