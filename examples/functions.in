#
# Simple functions which take no parameters, and
# return fixed values.
#
function four () {
   return( 4 );
}
function five () {
   return (3 + 2);
}

#
# Call the functions and confirm that works
#
let a = four();
let b = five();
println( "four() -> ", a, " five() -> ", b)


#
# Of course calling a function doesn't mean
# we have to care about the return value.
#
four();


#
# Set some global variables
#
let a = 13;
let b = 17;

println("Before function A is: ", a);
println("Before function B is: ", b);

#
# Define a function to show that it gets
# it's own scope, and the varibles have
# different values
#
function debug(a, b) {

   print("  Inside debug() A is ", a, "\n");
   print("  Inside debug() B is ", b, "\n");

}

#
# Call the function
#
debug(33, 42);

#
# And confirm the global scope is unchanged
#
println("A should still be 13: ", a);
println("B should still be 17: ", b);





#
# Return the maximum value of those
# values stored in variable A and B
#
function max (a, b ) {

   print("max() was called!\n");

   # If B > A then update A
   #
   # End result is A contains the
   # biggest of A and B.

   if ( b >= a ) {
      return( b );
   }
   return (a);
}

#
# Define a function with inline assembly
#
function steve () {
  inline {
      # Set the return value
      mov rax, 42
      # cleanup stack-frame
      mov rsp, rbp
      pop rbp
      ret
  }
}


let p = max(210, 121);
print("Result of max(): ", p, "\n");

let b = steve();
print("Result of steve() -> ", b, "\n");