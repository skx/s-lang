#
# Demonstrate accessing each character of a string.
#

function dump(s) {
  let length = strlen(s);
  let i = 0;

  while( i < length ) {
     let c = s[i];
     print( c, " ", );
     putc(c);
     newline();
     let i = i + 1;
  }
}

let a = "Hello, world!";
dump(a);

dump("I said \"Hello, world!\".\n");
