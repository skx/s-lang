# Calculate and print the first 100 prime numbers.

let count = 0;
let number = 2;

while ( count < 100 ) {

    let isPrime = 1;
    let divisor = 2;

    let max = sqrt(number);

    # If we've not ruled it out, and we're not above
    # the mid-way then keep going.
    while ( isPrime && divisor <= max ) {

        # If divisor divides number exactly, it is not prime
        if ( number % divisor == 0 ) {
            let isPrime = 0;
        }

        divisor++;
    }

    if ( isPrime ) {
        print( "Prime ", number, "\n" );
        count++;
    }

    number++;
}