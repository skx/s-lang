#
# Naive recursive factorial program
#

function fact(x) {
    if ( x < 2 ) {
       return (1);
    }
    return( x * fact(x - 1) );
}


let m = 20; # Max number to calculate
let n = 1;  # Current value being calculated

while ( n < m ) {

  print( "Calculating the factorial of ", n);

  let f = fact(n);

  print(" result ", f, "\n" );

  let n = n + 1;
}