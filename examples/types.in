#
# Show type of variables.
#

print( "Type of int : \n");
let tmp = 332;
print("\t", type(tmp), "\n" );

let b = type(tmp);
print( "\t", b, "\n");
newline();


print( "Type of string : \n");
let tmp = "Steve";
print("\t", type(tmp), "\n");

let b = type(tmp);
print( "\t", b, "\n");
newline();

#
# Confirm that the type persists in called functions
#
function typePrint( x ) {
   print("Value:", x, " Type:", type(x), "\n");
}

let a = 43;
typePrint(a);
let a = "This is the end";
typePrint(a);
